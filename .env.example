# Server Runtime
NODE_ENV=production
PORT=5000

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/jeevo?retryWrites=true&w=majority

# Auth
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRE=7d

# Frontend URL used by CORS and email links
CLIENT_URL=https://your-frontend.vercel.app
CLIENT_URLS=https://your-frontend.vercel.app,https://your-preview-frontend.vercel.app

# Email (optional but recommended)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# SMS (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Maps (optional)
MAPBOX_ACCESS_TOKEN=

# Upload limits
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads
